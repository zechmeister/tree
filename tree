#!/bin/sh

set -e

branch="$1"
if [ -z "$branch" ]; then
  echo "Usage: tree <branch-name>"
  exit 1
fi

repo_root=$(git rev-parse --show-toplevel 2>/dev/null) || {
  echo "Not inside a git repository."
  exit 1
}

repo_name=$(basename "$repo_root")
worktree_path="$repo_root/../${repo_name}-worktrees/$branch"

if ! git show-ref --quiet "refs/heads/$branch"; then
  echo "Branch '$branch' doesn't exist. Creating from HEAD..."
  git branch "$branch"
fi

echo "Creating worktree at $worktree_path..."
git worktree add "$worktree_path" "$branch"

if [ -f "$repo_root/.worktreeinclude" ]; then
  while IFS= read -r path || [ -n "$path" ]; do
    case "$path" in
      ''|\#*) continue ;;
    esac
    path=${path%/}
    path=${path%/\*\*}
    path=${path%/\*}
    src="$repo_root/$path"
    if [ -d "$src" ]; then
      echo "Copying $path/ to worktree..."
      mkdir -p "$worktree_path/$path"
      cp -R "$src/." "$worktree_path/$path/"
    elif [ -e "$src" ]; then
      echo "Copying $path to worktree..."
      mkdir -p "$worktree_path/$(dirname "$path")"
      cp -R "$src" "$worktree_path/$path"
    fi
  done < "$repo_root/.worktreeinclude"
fi

cd "$worktree_path"
exec "${SHELL:-/bin/sh}"

